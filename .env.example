# Supabase — from `npx supabase status` locally, or the project dashboard in prod
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only: webhooks + admin scripts, never in the client bundle
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Paddle (subscription billing, sandbox until launch)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
