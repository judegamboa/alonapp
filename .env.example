# Supabase — from `npx supabase status` locally; production values live in
# Vercel env (project fvsupccynnhqeywpuukg, https://www.alonapp.com)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only: webhooks + admin scripts, never in the client bundle
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth — the only freelancer sign-in. These belong in `.env` (NOT
# .env.local): the Supabase CLI auto-loads `.env` at `supabase start` and
# substitutes them into config.toml, but it never reads .env.local. Without
# them there is no way into local dev. Google Cloud console → Credentials →
# OAuth client (Web), authorized redirect URI
# http://127.0.0.1:54321/auth/v1/callback. Prod uses a SEPARATE client, set in
# the Supabase dashboard — see README and DECISIONS.md.
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Resend (transactional email). Unset locally = emails are logged and skipped.
# Verify alonapp.com in Resend before production sends.
RESEND_API_KEY=
RESEND_FROM=notifications@alonapp.com

# Paddle (subscription billing, sandbox until launch). All unset = billing is
# inert: the webhook returns 503 and Settings offers a local plan switcher
# instead of checkout. Webhook endpoint: /api/webhooks/paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=          # notification-setting secret; verifies Paddle-Signature
PADDLE_PRICE_STARTER=           # price ID that maps to the starter plan
PADDLE_PRICE_PRO=               # price ID that maps to the pro plan
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=  # client-side token for Paddle.js checkout
NEXT_PUBLIC_PADDLE_ENV=sandbox    # sandbox | production

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
